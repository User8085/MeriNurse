# 🏥 MeriNurse - Environment Variables Configuration
# Copy this file to '.env' and fill in your actual credentials.
# Do NOT commit your actual '.env' file containing secrets to version control.

# ==============================================================================
# 📡 Server Configuration
# ==============================================================================
PORT=5000
NODE_ENV=development
CLIENT_URL=https://meri-nurse.vercel.app

# ==============================================================================
# 🗄️ Database (MongoDB)
# ==============================================================================
# Connection URI for your MongoDB database (Local or MongoDB Atlas)
MONGODB_URI=mongodb://localhost:27017/merinurse

# ==============================================================================
# 🔑 Authentication (JWT)
# ==============================================================================
# A strong, unique, random string used to sign JSON Web Tokens
JWT_SECRET=your_jwt_super_secret_key_change_this_in_production
# Expiration time for authentication tokens (e.g., 7d, 24h, 1h)
JWT_EXPIRE=7d

# ==============================================================================
# 🤖 AI Integration (Google Gemini AI)
# ==============================================================================
# Required for: AI Chatbot assistance, medical record summaries, and document analysis.
# Get a free key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ==============================================================================
# 💊 Drug Databases & Public Health APIs
# ==============================================================================
# OpenFDA API Key - Used for drug detail lookups and cross-referencing adverse events.
# Get a key at: https://open.fda.gov/apis/authentication/ (recommended to avoid rate limiting)
OPENFDA_API_KEY=your_openfda_api_key_here

# ==============================================================================
# 📁 File Upload Settings
# ==============================================================================
# Maximum allowed size for uploaded files in bytes (default: 10MB = 10485760 bytes)
MAX_FILE_SIZE=10485760
# Relative or absolute directory path where uploaded patient medical documents will be stored
UPLOAD_PATH=./uploads
